<Window xmlns="https://github.com/avaloniaui"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   mc:Ignorable="d" d:DesignWidth="350" d:DesignHeight="666"
                   x:Class="Pap.erNet.Views.MainWindow"
		           xmlns:vm="using:Pap.erNet.ViewModels"
                   x:DataType="vm:MainWindowViewModel"
                   xmlns:home="clr-namespace:Pap.erNet.Pages.Home"
                   xmlns:settings="clr-namespace:Pap.erNet.Pages.Settings"
                   Icon="/Assets/logo.ico"
                   Title="Pap.erNet"
                   TransparencyLevelHint="AcrylicBlur"
                   Background="Transparent"
                   Width="350" Height="666"
		           MaxWidth="350" MaxHeight="666"
		           MinWidth="350" MinHeight="666"
		           Focusable="True"
                   x:Name="WallpaperWindow"
		           Closing="Window_Closing"
		           WindowStartupLocation="CenterScreen"
                   >
    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>
    <Panel>
        <ExperimentalAcrylicBorder IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial
                    BackgroundSource="Digger"
                    TintColor="Black"
                    TintOpacity="1"
                    MaterialOpacity="0.65"
                ></ExperimentalAcrylicMaterial>
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- 顶部标题栏和设置按钮 -->
            <Grid Grid.Row="0" Margin="16 8 16 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" 
                           Text="Pap.erNet" 
                           FontSize="16" 
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Foreground="White"/>
                <Button Grid.Column="1" 
                        x:Name="SettingsButton"
                        Click="SettingsButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="8"
                        VerticalAlignment="Center">
                    <PathIcon Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" 
                              Foreground="White"
                              Width="20" 
                              Height="20"/>
                </Button>
            </Grid>
            
            <!-- 主内容区 -->
            <StackPanel Grid.Row="1" Orientation="Vertical"
                        HorizontalAlignment="Center"
            >
                <TabControl Margin="0 8 0 0"
							SelectedIndex="0" 
                            Padding="0"
							SelectionChanged="TabChange"
							ItemsSource="{Binding WallpaperListViewModels}"
							DisplayMemberBinding="{Binding Header, x:DataType=vm:HeaderWithWallpaperListViewModel}"
                            >
                    <TabControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal"></StackPanel>
                        </ItemsPanelTemplate>
                    </TabControl.ItemsPanel>
					<TabControl.DataTemplates>
						<DataTemplate x:DataType="vm:HeaderWithWallpaperListViewModel">
							<home:WallpaperListView DataContext="{Binding WallpaperListViewModel}"></home:WallpaperListView>
						</DataTemplate>
					</TabControl.DataTemplates>
                </TabControl>
            </StackPanel>
            
            <!-- 设置面板 -->
            <settings:SettingsView Grid.Row="1" 
                                   x:Name="SettingsPanel"
                                   IsVisible="False"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"/>
        </Grid>
    </Panel>
</Window>

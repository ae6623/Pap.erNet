<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="350" d:DesignHeight="600"
             x:Class="Pap.erNet.Pages.Settings.SettingsView"
             xmlns:vm="using:Pap.erNet.ViewModels"
             x:DataType="vm:SettingsViewModel">
    <Design.DataContext>
        <vm:SettingsViewModel/>
    </Design.DataContext>
    
    <Panel Background="#CC000000">
        <ScrollViewer Margin="16">
            <StackPanel Spacing="16">
                <!-- 标题 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            x:Name="BackButton"
                            Click="BackButton_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="8 0 8 0"
                            Margin="-8 0 0 0">
                        <PathIcon Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" 
                                  Foreground="White"
                                  Width="24" 
                                  Height="24"/>
                    </Button>
                    <TextBlock Grid.Column="1"
                               Text="设置" 
                               FontSize="18" 
                               FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="-32 0 0 0"/>
                </Grid>
                
                <!-- 自动换壁纸设置 -->
                <Border Background="#22FFFFFF" 
                        CornerRadius="12" 
                        Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="自动换壁纸" 
                                   FontSize="16" 
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        
                        <!-- 开关 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="启用自动更换" 
                                       FontSize="14"
                                       Foreground="#CCFFFFFF"
                                       VerticalAlignment="Center"/>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding AutoWallpaperEnabled}"
                                          OnContent="" 
                                          OffContent=""/>
                        </Grid>
                        
                        <!-- 时间间隔 -->
                        <Grid IsEnabled="{Binding AutoWallpaperEnabled}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="更换间隔" 
                                       FontSize="14"
                                       Foreground="#CCFFFFFF"
                                       VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      SelectedItem="{Binding SelectedInterval}"
                                      ItemsSource="{Binding IntervalOptions}"
                                      Width="140"
                                      Background="#33FFFFFF"
                                      Foreground="White"
                                      BorderBrush="#44FFFFFF">
                                <ComboBox.Styles>
                                    <Style Selector="ComboBoxItem">
                                        <Setter Property="Foreground" Value="Black"/>
                                    </Style>
                                </ComboBox.Styles>
                            </ComboBox>
                        </Grid>
                        
                        <!-- 保存路径 -->
                        <Grid IsEnabled="{Binding AutoWallpaperEnabled}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Text="壁纸保存位置" 
                                       FontSize="14"
                                       Foreground="#CCFFFFFF"
                                       Margin="0 0 0 8"/>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding SavePath}"
                                         IsReadOnly="True"
                                         Background="#33FFFFFF"
                                         Foreground="White"
                                         BorderBrush="#44FFFFFF"
                                         Padding="8 6"
                                         Margin="0 0 8 0"/>
                                <StackPanel Grid.Column="1" 
                                        Orientation="Horizontal" 
                                        Spacing="8">
                                <Button Content="选择"
                                        Click="SelectFolder_Click"
                                        Background="#44FFFFFF"
                                        Foreground="White"
                                        Padding="12 6"
                                        BorderThickness="0"/>
                                <Button Click="OpenFolder_Click"
                                        Background="#33FFFFFF"
                                        Foreground="White"
                                        Padding="8 6"
                                        BorderThickness="0"
                                        ToolTip.Tip="打开文件夹">
                                    <PathIcon Data="M6,2H14L20,8V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V4A2,2 0 0,1 6,2M13,3.5V9H18.5L13,3.5M6,12V14H15V12H6M6,16V18H15V16H6Z" 
                                              Width="16" 
                                              Height="16"/>
                                </Button>
                            </StackPanel>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- 当前状态 -->
                <Border Background="#22FFFFFF" 
                        CornerRadius="12" 
                        Padding="16"
                        IsVisible="{Binding AutoWallpaperEnabled}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="状态" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock Text="{Binding StatusText}" 
                                   FontSize="12"
                                   Foreground="#AAFFFFFF"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                
                <!-- 关于 -->
                <Border Background="#22FFFFFF" 
                        CornerRadius="12" 
                        Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="关于" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock Text="Pap.erNet - 高仿 pap.er 的 Windows 版本" 
                                   FontSize="12"
                                   Foreground="#AAFFFFFF"/>
                        <TextBlock Text="自动换壁纸功能会定时从 pap.er 下载精美壁纸并设置为桌面背景" 
                                   FontSize="11"
                                   Foreground="#88FFFFFF"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Panel>
</UserControl>
